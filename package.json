{
  "name": "vtex-snap",
  "version": "2.9.2",
  "description": "CLI to clone a complete VTEX store catalog to another VTEX store",
  "homepage": "https://vtexsnap.zeluizr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeluizr/vtex-snap.git"
  },
  "bugs": {
    "url": "https://github.com/zeluizr/vtex-snap/issues"
  },
  "type": "module",
  "bin": {
    "vtex-snap": "./bin/vtex-snap"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\" && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
